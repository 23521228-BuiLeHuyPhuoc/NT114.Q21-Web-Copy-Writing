@startuml CopyProAdminUseCase
title CopyPro - Use Case quản trị

left to right direction

actor "Ứng viên Admin" as AdminCandidate
actor "Admin" as Admin
actor "Super Admin" as SuperAdmin

SuperAdmin --|> Admin

rectangle "Cổng quản trị CopyPro" {
  usecase "Đăng ký tài khoản Admin" as UC_Register

  usecase "Đăng nhập Admin" as UC_Login
  usecase "Xem dashboard quản trị" as UC_Dashboard
  usecase "Đăng xuất Admin" as UC_Logout

  usecase "Quản lý người dùng" as UC_Users
  usecase "Tạo tài khoản người dùng" as UC_CreateUser
  usecase "Cập nhật tài khoản người dùng" as UC_UpdateUser
  usecase "Vô hiệu hóa tài khoản" as UC_DeactivateUser
  usecase "Khôi phục tài khoản" as UC_RestoreUser

  usecase "Duyệt tài khoản Admin" as UC_ApproveAdmin
  usecase "Từ chối tài khoản Admin" as UC_RejectAdmin

  usecase "Quản lý vai trò và quyền" as UC_Permissions
  usecase "Tạo vai trò quản trị" as UC_CreateAdminRole
  usecase "Gán quyền cho vai trò" as UC_AssignPermission
  usecase "Khôi phục phân quyền mặc định" as UC_ResetPermissions

  usecase "Quản lý nội dung hệ thống" as UC_Contents
  usecase "Quản lý mẫu nội dung" as UC_Templates
  usecase "Quản lý danh mục" as UC_Categories

  usecase "Quản lý gói dịch vụ" as UC_Plans
  usecase "Quản lý giao dịch thanh toán" as UC_Payments
  usecase "Theo dõi doanh thu" as UC_Revenue

  usecase "Cấu hình hệ thống" as UC_Settings
  usecase "Cập nhật cấu hình API/AI" as UC_ApiSettings
  usecase "Cập nhật cấu hình bảo mật" as UC_SecuritySettings
  usecase "Cập nhật cấu hình thông báo" as UC_SystemNotifications

  usecase "Xem nhật ký quản trị" as UC_AuditLogs

  usecase "Quản lý mô hình AI" as UC_Models
}

AdminCandidate -- UC_Register
AdminCandidate -- UC_Login

Admin -- UC_Login
Admin -- UC_Dashboard
Admin -- UC_Logout

Admin -- UC_Users
Admin -- UC_CreateUser
Admin -- UC_UpdateUser
Admin -- UC_DeactivateUser
Admin -- UC_RestoreUser
Admin -- UC_Contents
Admin -- UC_Templates
Admin -- UC_Categories
Admin -- UC_Plans
Admin -- UC_Payments
Admin -- UC_Revenue
Admin -- UC_Settings
Admin -- UC_ApiSettings
Admin -- UC_SecuritySettings
Admin -- UC_SystemNotifications
Admin -- UC_AuditLogs
Admin -- UC_Models

SuperAdmin -- UC_ApproveAdmin
SuperAdmin -- UC_RejectAdmin
SuperAdmin -- UC_Permissions
SuperAdmin -- UC_CreateAdminRole
SuperAdmin -- UC_AssignPermission
SuperAdmin -- UC_ResetPermissions

UC_CreateUser ..> UC_Users : <<extend>>
UC_UpdateUser ..> UC_Users : <<extend>>
UC_DeactivateUser ..> UC_Users : <<extend>>
UC_RestoreUser ..> UC_Users : <<extend>>

UC_ApproveAdmin ..> UC_Users : <<extend>>
UC_RejectAdmin ..> UC_Users : <<extend>>

UC_CreateAdminRole ..> UC_Permissions : <<extend>>
UC_AssignPermission ..> UC_Permissions : <<extend>>
UC_ResetPermissions ..> UC_Permissions : <<extend>>

UC_Revenue ..> UC_Payments : <<extend>>

UC_ApiSettings ..> UC_Settings : <<extend>>
UC_SecuritySettings ..> UC_Settings : <<extend>>
UC_SystemNotifications ..> UC_Settings : <<extend>>

@enduml
