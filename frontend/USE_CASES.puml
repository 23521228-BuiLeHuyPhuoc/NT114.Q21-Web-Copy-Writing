@startuml CopyProOverview
' CopyPro overview use case diagram.
' Use cases are organized around user-role actors.

!pragma layout smetana
title CopyPro - Use Case tổng quan

left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam actorStyle awesome
skinparam linetype polyline
skinparam nodesep 28
skinparam ranksep 35
skinparam defaultFontName "Segoe UI"
skinparam ArrowColor #475569
skinparam actor {
  BackgroundColor #F8FAFC
  BorderColor #334155
}
skinparam usecase {
  BackgroundColor #F8FFFB
  BorderColor #15803D
}
skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #94A3B8
}

actor "Người dùng" as User
actor "Khách truy cập" as Guest
actor "Khách hàng" as Customer
actor "Ứng viên Admin" as AdminCandidate
actor "Admin" as Admin
actor "Super Admin" as SuperAdmin

Guest --|> User
Customer --|> Guest
AdminCandidate --|> User
Admin --|> User
SuperAdmin --|> Admin

rectangle "Hệ thống CopyPro" {
  package "Công khai và tài khoản" {
    usecase "Xem thông tin công khai" as O_PublicInfo
    usecase "Đọc blog" as O_ReadBlog
    usecase "Gửi yêu cầu liên hệ" as O_Contact
    usecase "Đăng ký tài khoản khách hàng" as O_CustomerRegister
    usecase "Đăng nhập khách hàng" as O_CustomerLogin
    usecase "Khôi phục mật khẩu" as O_RecoverPassword
    usecase "Đăng ký tài khoản Admin" as O_AdminRegister
    usecase "Đăng nhập Admin" as O_AdminLogin
  }

  package "Cổng khách hàng" {
    usecase "Xem dashboard khách hàng" as O_CustomerDashboard
    usecase "Tạo nội dung AI" as O_GenerateContent
    usecase "Quản lý nội dung đã tạo" as O_ManageContents
    usecase "Quản lý dự án" as O_ManageProjects
    usecase "Sử dụng thư viện mẫu" as O_TemplateLibrary
    usecase "Tinh chỉnh mô hình" as O_FineTune
    usecase "Kiểm tra đạo văn" as O_Plagiarism
    usecase "Cập nhật hồ sơ" as O_Profile
    usecase "Quản lý gói dịch vụ" as O_ManageSubscription
    usecase "Thanh toán gói dịch vụ" as O_PaySubscription
    usecase "Xem hóa đơn" as O_Invoices
    usecase "Xem thông báo" as O_Notifications
  }

  package "Cổng quản trị" {
    usecase "Xem dashboard quản trị" as O_AdminDashboard
    usecase "Quản lý người dùng" as O_AdminUsers
    usecase "Duyệt tài khoản Admin" as O_ApproveAdmin
    usecase "Quản lý nội dung hệ thống" as O_AdminContents
    usecase "Quản lý mẫu nội dung" as O_AdminTemplates
    usecase "Quản lý danh mục" as O_AdminCategories
    usecase "Quản lý gói dịch vụ" as O_AdminPlans
    usecase "Quản lý giao dịch thanh toán" as O_AdminPayments
    usecase "Quản lý mô hình AI" as O_AdminModels
    usecase "Cấu hình hệ thống" as O_AdminSettings
    usecase "Xem nhật ký quản trị" as O_AdminAuditLogs
    usecase "Quản lý vai trò và quyền" as O_AdminPermissions
  }
}

User -- O_PublicInfo
User -- O_ReadBlog
User -- O_Contact
User -- O_RecoverPassword

Guest -- O_CustomerRegister
Guest -- O_CustomerLogin

AdminCandidate -- O_AdminRegister
AdminCandidate -- O_AdminLogin

Customer -- O_CustomerDashboard
Customer -- O_GenerateContent
Customer -- O_ManageContents
Customer -- O_ManageProjects
Customer -- O_TemplateLibrary
Customer -- O_FineTune
Customer -- O_Plagiarism
Customer -- O_Profile
Customer -- O_ManageSubscription
Customer -- O_PaySubscription
Customer -- O_Invoices
Customer -- O_Notifications

Admin -- O_AdminLogin
Admin -- O_AdminDashboard
Admin -- O_AdminUsers
Admin -- O_AdminContents
Admin -- O_AdminTemplates
Admin -- O_AdminCategories
Admin -- O_AdminPlans
Admin -- O_AdminPayments
Admin -- O_AdminModels
Admin -- O_AdminSettings
Admin -- O_AdminAuditLogs

SuperAdmin -- O_ApproveAdmin
SuperAdmin -- O_AdminPermissions

O_PaySubscription ..> O_ManageSubscription : <<extend>>

@enduml

