PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/ai-copywriter
FRONTEND_URL=http://localhost:3000
JWT_SECRET=change_me_in_real_env
JWT_EXPIRES_IN=7d
ADMIN_INVITE_CODE=ADMIN2026
OTP_EXPIRES_MINUTES=5
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Options: gemini, groq, openrouter, openai, freegpt4, auto.
AI_PROVIDER=gemini

# AI provider API keys
# Leave provider-specific *_MODEL empty so the model selected in the UI is used.
# UI ids free/working: gemini-flash, gemini-flash-lite, gemini-3-flash-preview, gemini-3-1-flash-lite, gemma-4-26b, openrouter-free, groq-llama-3-3-70b, groq-llama-3-1-8b.
GEMINI_API_KEY=
GEMINI_MODEL=

# Google Gemini tuning is not supported by Gemini API keys.
# Use Vertex AI / Gemini Enterprise Agent Platform credentials for real tuning.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Leave empty when using gcloud Application Default Credentials locally
# or an attached service account on Cloud Run/GCE/GKE.
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_TUNING_BUCKET=
VERTEX_TUNING_BASE_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite

# Hugging Face / AutoTrain fine-tuning configuration.
# Do not commit real tokens. Use a fresh write token in local .env only.
HF_TOKEN=
HF_USERNAME=
HF_FINE_TUNE_BASE_MODEL=
HF_FINE_TUNE_OUTPUT_REPO=
HF_AUTOTRAIN_PROJECT_NAME=copypro-finetune
HF_AUTOTRAIN_HARDWARE=
GROQ_API_KEY=
GROQ_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=CopyPro AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Free-GPT4-WEB-API local generation endpoint.
# Start it with: python3 src/FreeGPT4_Server.py
FREEGPT4_BASE_URL=http://127.0.0.1:5500
FREEGPT4_MODEL=gpt-4
FREEGPT4_KEYWORD=text
FREEGPT4_TIMEOUT_MS=90000

# Real fine-tuning is separate from AI Generator inference models.
# Set one of these only when the endpoint supports /files and /fine_tuning/jobs.
OPENAI_FINE_TUNE_MODEL=
OPENAI_FINE_TUNE_BASE_MODELS=

# Payment gateways
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_RETURN_URL=
VNPAY_IPN_URL=

ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
ZALOPAY_QUERY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/query
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
ZALOPAY_RETURN_URL=
ZALOPAY_CALLBACK_URL=
ZALOPAY_BANK_CODE=zalopayapp
ZALOPAY_MIN_AMOUNT=1000
PAYMENT_GATEWAY_TIMEOUT_MS=15000
NGROK=
