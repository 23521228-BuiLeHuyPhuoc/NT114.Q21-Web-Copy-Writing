PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/ai-copywriter
FRONTEND_URL=http://localhost:3000
JWT_SECRET=change_me_in_real_env
JWT_EXPIRES_IN=7d
ADMIN_INVITE_CODE=ADMIN2026
OTP_EXPIRES_MINUTES=5
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
AI_PROVIDER=gemini

# Gemini API
# Leave GEMINI_MODEL empty so the model selected in the UI is used.
# UI ids free/working: gemini-flash, gemini-flash-lite, gemini-3-flash-preview, gemini-3-1-flash-lite, gemma-4-26b, openrouter-free.
GEMINI_API_KEY=
GEMINI_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=CopyPro AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
