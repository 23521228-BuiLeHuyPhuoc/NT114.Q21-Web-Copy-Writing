PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/ai-copywriter
FRONTEND_URL=http://localhost:3000
JWT_SECRET=change_me_in_real_env
JWT_EXPIRES_IN=7d
ADMIN_INVITE_CODE=ADMIN2026
OTP_EXPIRES_MINUTES=5

# Cloudinary avatar uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_AVATAR_FOLDER=copypro/avatars/users

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Default provider. Generation supports: gemini, vertex-gemini, vertex-maas, groq, openrouter, openai, freegpt4, auto.
# Fine-tuning supports real training providers: vertex-gemini, vertex-llama, vertex-qwen, vertex-claude.
AI_PROVIDER=gemini

# AI provider API keys
# Leave provider-specific *_MODEL empty so the model selected in the UI is used.
# UI ids free/working: gemini-flash, gemini-flash-lite, gemini-3-flash-preview, gemini-3-1-flash-lite, gemma-4-26b, openrouter-free, groq-llama-3-3-70b, groq-llama-3-1-8b, meta/llama-3.3-70b-instruct-maas.
GEMINI_API_KEY=
GOOGLE_API_KEY=
VERTEX_API_KEY=
GOOGLE_GENAI_USE_ENTERPRISE=false
GEMINI_MODEL=

# Google Gemini tuning is not supported by Gemini API keys.
# Use Vertex AI / Gemini Enterprise Agent Platform credentials for real tuning.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Leave empty when using gcloud Application Default Credentials locally
# or an attached service account on Cloud Run/GCE/GKE.
GOOGLE_APPLICATION_CREDENTIALS=

# Vertex AI MaaS generation. UI can send the model id directly; set these only to override defaults.
VERTEX_MAAS_MODEL=
VERTEX_MAAS_LOCATION=
VERTEX_MAAS_TIMEOUT_MS=120000
VERTEX_ENDPOINT_TIMEOUT_MS=120000

# Vertex AI Claude via Anthropic partner models.
# Use multiple locations so the app can retry when one location's base-model quota is exhausted.
VERTEX_CLAUDE_MODEL=
VERTEX_CLAUDE_LOCATIONS=us-east5,europe-west1,asia-east1,global
VERTEX_CLAUDE_TIMEOUT_MS=120000

VERTEX_TUNING_BUCKET=
VERTEX_TUNING_BASE_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite

# Vertex AI managed open-model tuning for Llama and Qwen.
# Requires: python -m pip install -r ../training/vertex_open_model_tuning/requirements.txt
# This creates a paid Vertex tuning job when selected in /fine-tune.
VERTEX_OPEN_MODEL_TUNING_BASE_MODELS=meta/llama3-3@llama-3.3-70b-instruct,qwen/qwen3@qwen3-14b
VERTEX_LLAMA_TUNING_BASE_MODELS=meta/llama3-3@llama-3.3-70b-instruct
VERTEX_QWEN_TUNING_BASE_MODELS=qwen/qwen3@qwen3-14b
# Optional target serving endpoint used only to pick the tuning region.
# If set, open-model tuning runs in the endpoint's location so tuned output can be deployed/tested in the same region.
VERTEX_OPEN_MODEL_TUNING_ENDPOINT=
VERTEX_LLAMA_TUNING_ENDPOINT=
VERTEX_QWEN_TUNING_ENDPOINT=
VERTEX_OPEN_MODEL_TUNING_PYTHON=.venv/Scripts/python.exe
VERTEX_OPEN_MODEL_TUNING_MODE=PEFT_ADAPTER
VERTEX_QWEN_TUNING_MODE=FULL
VERTEX_OPEN_MODEL_TUNING_OUTPUT_GCS_URI=
# Backward-compatible aliases for existing Llama config.
VERTEX_LLAMA_TUNING_PYTHON=
VERTEX_LLAMA_TUNING_MODE=
VERTEX_LLAMA_TUNING_OUTPUT_GCS_URI=
# Optional: 1, 4, 8, 16, or 32.
VERTEX_OPEN_MODEL_TUNING_ADAPTER_SIZE=
VERTEX_LLAMA_TUNING_ADAPTER_SIZE=
GROQ_API_KEY=
GROQ_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=CopyPro AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Plagiarism web check: SerpApi finds candidate URLs; Common Crawl fetches archived snapshots.
SERPAPI_API_KEY=
SERPAPI_NUM_RESULTS=10
SERPAPI_MAX_RESULTS=12
COMMON_CRAWL_TOTAL_BUDGET_MS=45000
COMMON_CRAWL_MAX_FETCHES=12

# Free-GPT4-WEB-API local generation endpoint.
# Start it with: python3 src/FreeGPT4_Server.py
FREEGPT4_BASE_URL=http://127.0.0.1:5500
FREEGPT4_MODEL=gpt-4
FREEGPT4_KEYWORD=text
FREEGPT4_TIMEOUT_MS=90000

# Real fine-tuning is separate from AI Generator inference models.
# Set one of these only when the endpoint supports /files and /fine_tuning/jobs.
OPENAI_FINE_TUNE_MODEL=
OPENAI_FINE_TUNE_BASE_MODELS=

# Payment gateways
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_RETURN_URL=
VNPAY_IPN_URL=

ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
ZALOPAY_QUERY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/query
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
ZALOPAY_RETURN_URL=
ZALOPAY_CALLBACK_URL=
ZALOPAY_BANK_CODE=zalopayapp
ZALOPAY_MIN_AMOUNT=1000
PAYMENT_GATEWAY_TIMEOUT_MS=15000
NGROK=
